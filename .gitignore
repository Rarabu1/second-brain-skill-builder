# Deny everything by default
*

# Allow root-level files
!index.html
!README.md
!.gitignore
!wrangler.jsonc
!.assetsignore
!og.png

# Allow warmup/ and its contents
!warmup/
!warmup/**

# Allow setup/ and its contents
!setup/
!setup/**

# Allow personalize/ and its contents
!personalize/
!personalize/**

# Allow prompts/ and its contents
!prompts/
!prompts/**

# Allow about/ and its contents
!about/
!about/**

# Allow field-notes/ and its contents
!field-notes/
!field-notes/**

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
.env*
!.env.example

# Held-back field notes (02-05): not yet reviewed, keep out of the public repo.
# When a note publishes, delete its line here in the same commit that lifts
# its .assetsignore hold.
field-notes/where-to-play/
field-notes/read-before-you-accept/
field-notes/untrusted-input/
field-notes/before-something-sensitive/

# Track deploy config and public root assets (were disk-only before).
!favicon.svg
!robots.txt
!sitemap.xml
!_headers
!predeploy-check.sh
!deploy.sh
