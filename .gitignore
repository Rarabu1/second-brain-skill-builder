# Deny everything by default
*

# Allow root-level files
!index.html
!README.md
!.gitignore
!wrangler.jsonc
!.assetsignore

# Allow warmup/ and its contents
!warmup/
!warmup/**

# Allow setup/ and its contents
!setup/
!setup/**

# Allow personalize/ and its contents
!personalize/
!personalize/**

# Allow prompts/ and its contents
!prompts/
!prompts/**

# Allow about/ and its contents
!about/
!about/**

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
.env*
!.env.example
